@page
@model IndexModel
@{
    ViewData["Title"] = "System Rezerwacji Miejsc Parkingowych";
}

<div class="text-center my-5">
    <h1 class="display-4 fw-bold" style="color: var(--rose-dark);"><i class="bi bi-p-circle-fill"></i> System Rezerwacji</h1>
    <p class="lead text-muted">Znajdź i zarezerwuj swoje idealne miejsce parkingowe przy uczelni.</p>
</div>

<div class="container mb-5">
    <div class="card search-card p-2">
        <div class="card-body">
            <form method="get" class="row g-3 justify-content-center align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-bold" style="color: var(--text-dark);">Data i godzina OD:</label>
                    <input type="datetime-local" asp-for="StartTime" class="form-control" 
                           value="@Model.StartTime.ToString("yyyy-MM-ddTHH:mm")" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold" style="color: var(--text-dark);">Data i godzina DO:</label>
                    <input type="datetime-local" asp-for="EndTime" class="form-control" 
                           value="@Model.EndTime.ToString("yyyy-MM-ddTHH:mm")" required />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-rose w-100 py-2.5 shadow-sm">
                        <i class="bi bi-search"></i> Sprawdź dostępność
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="container">
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger rounded-3 border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success rounded-3 border-0 shadow-sm mb-4" style="background-color: var(--spot-free-bg); color: var(--text-dark);" role="alert">
            <i class="bi bi-check-circle-fill" style="color: var(--spot-free);"></i> @TempData["SuccessMessage"]
        </div>
    }

    <div class="mb-4 text-muted text-center bg-white d-inline-block px-4 py-2 rounded-pill shadow-sm mx-auto d-block" style="width: fit-content; border: 1px solid var(--rose-light);">
        Wybrany zakres czasu: 
        <strong style="color: var(--rose-dark);">@Model.StartTime.ToString("dd.MM.yyyy HH:mm")</strong> do <strong style="color: var(--rose-dark);">@Model.EndTime.ToString("dd.MM.yyyy HH:mm")</strong>
    </div>

    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var spot in Model.ParkingSpots)
        {
            bool isOccupiedNow = Model.OccupiedSpotIds.Contains(spot.Id);

            <div class="col">
                <div class="card h-100 text-center parking-card @(isOccupiedNow ? "border-spot-occupied" : "border-spot-free")">
                    <div class="card-header text-white @(isOccupiedNow ? "bg-spot-occupied" : "bg-spot-free")">
                        <h5 class="my-0 fw-bold"><i class="bi bi-geo-alt-fill"></i> Miejsce @spot.SpotNumber</h5>
                    </div>
                    <div class="card-body d-flex flex-column justify-content-between p-4">
                        <div class="my-2">
                            <h1 class="card-title">
                                <i class="bi @(isOccupiedNow ? "bi-car-front-fill text-spot-occupied" : "bi-p-circle-fill text-spot-free")" style="font-size: 3.5rem;"></i>
                            </h1>
                            <span class="badge rounded-pill px-3 py-2 mt-2 @(isOccupiedNow ? "bg-subtle-occupied text-spot-occupied" : "bg-subtle-free text-spot-free")" style="font-size: 0.9rem; font-weight: 600;">
                                @(isOccupiedNow ? "Zajęte" : "Dostępne")
                            </span>
                        </div>

                        <div class="mt-4">
                            @if (User.Identity != null && User.Identity.IsAuthenticated)
                            {
                                if (!isOccupiedNow)
                                {
                                    <form method="post" asp-page-handler="Reserve">
                                        <input type="hidden" name="spotId" value="@spot.Id" />
                                        <input type="hidden" name="startTime" value="@Model.StartTime.ToString("yyyy-MM-ddTHH:mm")" />
                                        <input type="hidden" name="endTime" value="@Model.EndTime.ToString("yyyy-MM-ddTHH:mm")" />
                                        
                                        <button type="submit" class="w-100 btn btn-spot-action shadow-sm py-2">
                                            <i class="bi bi-calendar-heart"></i> Rezerwuj slot
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <button class="w-100 btn btn-light py-2 text-muted" style="border: 1px dashed #ccc;" disabled>
                                        <i class="bi bi-lock-fill"></i> Niedostępne
                                    </button>
                                }
                            }
                            else
                            {
                                <a asp-page="/Login" class="w-100 btn btn-outline-secondary py-2" style="border-color: var(--rose-primary); color: var(--text-dark);">
                                    <i class="bi bi-box-arrow-in-right"></i> Zaloguj się
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>